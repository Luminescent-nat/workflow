{
  "name": "auto-flows",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:themes && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:themes": "node src-tauri/codex-theme-switcher/node_modules/typescript/bin/tsc -p src-tauri/codex-theme-switcher/tsconfig.json",
    "postinstall": "node -e \"require('node:child_process').execFileSync(process.execPath, [process.env.npm_execpath, '--prefix', 'src-tauri/codex-theme-switcher', 'install'], { stdio: 'inherit' })\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
